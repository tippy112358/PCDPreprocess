#  O3D OffscreenRenderer 版本 (更稠密，稍慢)
# ============================================================

class O3DPointCloudRenderer:
    """
    O3D OffscreenRenderer 渲染
    适合需要更稠密效果的场景
    """

    def __init__(self, ply_path: str, max_points: int = None):
        t0 = time.time()
        self.pcd = o3d.io.read_point_cloud(ply_path)

        if max_points and len(self.pcd.points) > max_points:
            points = np.asarray(self.pcd.points)
            bbox = points.max(0) - points.min(0)
            vs = (np.prod(bbox) / max_points) ** (1 / 3)
            for _ in range(10):
                down = self.pcd.voxel_down_sample(vs)
                ratio = len(down.points) / max_points
                if 0.9 < ratio < 1.1:
                    break
                vs *= ratio ** (1 / 3)
            self.pcd = down

        self.N = len(self.pcd.points)
        # renderer 缓存: (w, h) → renderer
        self._renderers = {}

        print(f"[O3DPointCloudRenderer] Loaded {self.N:,} points "
              f"from {ply_path} in {time.time() - t0:.2f}s")

    def _get_renderer(self, img_w, img_h, point_size):
        key = (img_w, img_h, point_size)
        if key not in self._renderers:
            renderer = rendering.OffscreenRenderer(img_w, img_h)
            renderer.scene.set_background(np.array([0, 0, 0, 1]))
            mat = rendering.MaterialRecord()
            mat.shader = "defaultUnlit"
            mat.point_size = point_size
            renderer.scene.add_geometry("pcd", self.pcd, mat)
            self._renderers[key] = renderer
        return self._renderers[key]

    def render(self, intrinsic: np.ndarray, extrinsic_w2c: np.ndarray,
               img_h: int, img_w: int, point_size: float = 3.0,
               return_mask: bool = True):
        """
        Returns:
            color_img: (3, H, W) float32 [0, 1]
            mask:      (1, H, W) float32 [0, 1]
        """
        renderer = self._get_renderer(img_w, img_h, point_size)

        fx, fy = intrinsic[0, 0], intrinsic[1, 1]
        cx, cy = intrinsic[0, 2], intrinsic[1, 2]
        pinhole = o3d.camera.PinholeCameraIntrinsic(
            img_w, img_h, fx, fy, cx, cy
        )
        renderer.setup_camera(pinhole, extrinsic_w2c)

        color_o3d = renderer.render_to_image()
        color_np = np.asarray(color_o3d)  # (H, W, 3) uint8

        color_out = color_np.transpose(2, 0, 1).astype(np.float32) / 255.0

        if return_mask:
            mask = np.any(color_np > 0, axis=-1).astype(np.float32)
            mask_out = mask[np.newaxis]
            return color_out, mask_out

        return color_out

    def cleanup(self):
        for r in self._renderers.values():
            r.scene.remove_geometry("pcd")
        self._renderers.clear()


