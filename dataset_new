class LidarProjectionDataset(Dataset):
    """
    点云投影 Dataset

    输入:
      - 场景列表 CSV (scene_path, ply_path)
      - 81 个目标相机 c2w 外参 (由外部传入或从文件加载)

    流程:
      1. 采样场景
      2. 采样轨迹
      3. 采样偏移量 (按权重)
      4. 采样源/目标相机 (按权重)
      5. 加载 PLY → CPU 投影 → 得到 lidar_rgb + lidar_mask
      6. 加载原始图像 → source_video + target_video
      7. 计算相对 pose (每 4 帧采样)

    Returns dict:
      source_video:     (3, T, H, W)
      target_video:     (3, T, H, W)
      render_lidar:     (3, T, H, W)  投影着色
      render_lidar_mask:(1, T, H, W)  投影 mask
      camera_embedding: (T//4+1, 12)  每 4 帧采样的 pose
    """

    def __init__(
        self,
        scene_csv_path: str,
        target_c2w_provider=None,       # 外部传入 c2w 的接口
        target_cam_json_key: str = "target",   # JSON 中目标相机的 key
        source_cam_json_key: str = "source",   # JSON 中源相机的 key
        num_frames: int = 81,
        height: int = 512,
        width: int = 1024,
        steps_per_epoch: int = 10000,
        # 渲染参数
        renderer_type: str = "o3d",      # "cpu" 或 "o3d"
        splat_size: int = 2,             # CPU 渲染的 splat 大小
        point_size: float = 3.0,         # O3D 渲染的点大小
        max_points: int = 3_000_000,     # 点云最大点数
        # 采样权重
        offset_weights: Dict[str, float] = None,   # {"0.0m": 1.0, "+1.0m": 0.5, ...}
        camera_weights: Dict[str, float] = None,   # {"FRONT_WIDE_...": 1.0, ...}
        # 相机内参 (渲染投影时使用，需外部提供)
        render_intrinsic: np.ndarray = None,        # (3,3) 渲染用内参
        # 每个相机的 splat_size / point_size 可调
        camera_splat_sizes: Dict[str, int] = None,  # {"FRONT_WIDE_...": 3, ...}
    ):
        super().__init__()

        self.num_frames = num_frames
        self.height = height
        self.width = width
        self.steps_per_epoch = steps_per_epoch
        self.renderer_type = renderer_type
        self.splat_size = splat_size
        self.point_size = point_size
        self.max_points = max_points
        self.camera_splat_sizes = camera_splat_sizes or {}
        self.target_c2w_provider = target_c2w_provider
        self.target_cam_json_key = target_cam_json_key
        self.source_cam_json_key = source_cam_json_key

        # 读取场景列表
        self.scene_df = pd.read_csv(scene_csv_path)
        # 期望列: scene_path, ply_path, (可选: cameras_json_path)
        assert 'scene_path' in self.scene_df.columns
        assert 'ply_path' in self.scene_df.columns

        # 解析每个场景的目录结构
        print("Parsing scene structures...")
        self.scene_structures = {}
        self.valid_scenes = []
        for idx, row in self.scene_df.iterrows():
            scene_path = row['scene_path']
            ply_path = row['ply_path']
            if not os.path.exists(scene_path):
                print(f"  [SKIP] Scene not found: {scene_path}")
                continue
            if not os.path.exists(ply_path):
                print(f"  [SKIP] PLY not found: {ply_path}")
                continue

            structure = parse_scene_structure(scene_path)
            if structure:
                self.scene_structures[idx] = {
                    'scene_path': scene_path,
                    'ply_path': ply_path,
                    'structure': structure,
                    'cameras_json': row.get('cameras_json_path', None),
                }
                self.valid_scenes.append(idx)

        print(f"Valid scenes: {len(self.valid_scenes)}")
        assert len(self.valid_scenes) > 0, "No valid scenes found!"

        # 渲染器缓存: ply_path → renderer
        self._renderer_cache = {}

        # 采样权重
        self.offset_weights = offset_weights or {o: 1.0 for o in OFFSET_LIST}
        self.camera_weights = camera_weights or {c: 1.0 for c in CAMERA_NAMES}

        # 归一化权重
        self._offset_names, self._offset_probs = self._normalize_weights(self.offset_weights)
        self._camera_names, self._camera_probs = self._normalize_weights(self.camera_weights)

        # 渲染用内参 (如果不提供，使用默认)
        if render_intrinsic is not None:
            self.render_intrinsic = render_intrinsic.astype(np.float32)
        else:
            # 默认内参 (需要替换为你的实际内参)
            self.render_intrinsic = np.array([
                [width * 0.8, 0, width / 2],
                [0, width * 0.8, height / 2],
                [0, 0, 1]
            ], dtype=np.float32)

        # 图像处理
        self.frame_process = v2.Compose([
            v2.CenterCrop(size=(height, width)),
            v2.Resize(size=(height, width), antialias=True),
            v2.ToTensor(),
            v2.Normalize(mean=[0.5, 0.5, 0.5], std=[0.5, 0.5, 0.5]),
        ])

    @staticmethod
    def _normalize_weights(weight_dict):
        names = list(weight_dict.keys())
        weights = np.array([weight_dict[n] for n in names], dtype=np.float64)
        probs = weights / weights.sum()
        return names, probs

    def _get_renderer(self, ply_path: str):
        """获取或创建渲染器 (缓存)"""
        if ply_path not in self._renderer_cache:
            if self.renderer_type == "o3d":
                self._renderer_cache[ply_path] = O3DPointCloudRenderer(
                    ply_path, max_points=self.max_points
                )
            else:
                self._renderer_cache[ply_path] = CPUPointCloudRenderer(
                    ply_path, max_points=self.max_points
                )
        return self._renderer_cache[ply_path]

    def crop_and_resize(self, image):
        """与原始代码保持一致的 crop_and_resize"""
        width, height = image.size
        scale = max(self.width / width, self.height / height)
        image = torchvision.transforms.functional.resize(
            image,
            (round(height * scale), round(width * scale)),
            interpolation=torchvision.transforms.InterpolationMode.BILINEAR
        )
        return image

    def load_image_as_tensor(self, path: str):
        """加载单张图片并处理为 tensor"""
        img = Image.open(path).convert("RGB")
        img = self.crop_and_resize(img)
        img = self.frame_process(img)
        return img  # (3, H, W)

    @staticmethod
    def get_relative_pose(cam_params):
        """计算相对 pose (与原始代码一致)"""
        abs_w2cs = [cam_param.w2c_mat for cam_param in cam_params]
        abs_c2ws = [cam_param.c2w_mat for cam_param in cam_params]
        target_cam_c2w = np.eye(4, dtype=np.float32)
        abs2rel = target_cam_c2w @ abs_w2cs[0]
        ret_poses = [target_cam_c2w] + [abs2rel @ abs_c2w for abs_c2w in abs_c2ws[1:]]
        ret_poses = np.array(ret_poses, dtype=np.float32)
        return ret_poses

    def _sample_offset(self, available_offsets: list):
        """按权重采样偏移量"""
        # 过滤出实际存在的偏移
        valid = [(n, p) for n, p in zip(self._offset_names, self._offset_probs)
                 if n in available_offsets]
        if not valid:
            return random.choice(available_offsets)
        names, probs = zip(*valid)
        probs = np.array(probs)
        probs = probs / probs.sum()
        return np.random.choice(names, p=probs)

    def _sample_camera(self, available_cameras: list):
        """按权重采样相机"""
        valid = [(n, p) for n, p in zip(self._camera_names, self._camera_probs)
                 if n in available_cameras]
        if not valid:
            return random.choice(available_cameras)
        names, probs = zip(*valid)
        probs = np.array(probs)
        probs = probs / probs.sum()
        return np.random.choice(names, p=probs)

    def _render_single_frame(self, renderer, c2w: np.ndarray, cam_name: str = None):
        """
        渲染单帧

        Args:
            renderer: CPUPointCloudRenderer 或 O3DPointCloudRenderer
            c2w: (4, 4) camera-to-world
            cam_name: 相机名 (用于获取该相机特定的 splat_size)

        Returns:
            color: (3, H, W) float32 [0, 1]
            mask:  (1, H, W) float32 [0, 1]
        """
        w2c = np.linalg.inv(c2w).astype(np.float32)

        if isinstance(renderer, O3DPointCloudRenderer):
            ps = self.camera_splat_sizes.get(cam_name, self.point_size) if cam_name else self.point_size
            return renderer.render(
                self.render_intrinsic, w2c,
                self.height, self.width,
                point_size=ps, return_mask=True
            )
        else:
            ss = self.camera_splat_sizes.get(cam_name, self.splat_size) if cam_name else self.splat_size
            return renderer.render(
                self.render_intrinsic, w2c,
                self.height, self.width,
                splat_size=ss, return_mask=True
            )

    def __len__(self):
        return self.steps_per_epoch

    def __getitem__(self, index):
        while True:
            try:
                return self._load_sample(index)
            except Exception as e:
                print(f"[LidarProjectionDataset] Error at index {index}: {e}")
                index = random.randrange(len(self.valid_scenes))

    def _load_sample(self, index):
        t_start = time.time()

        # ---- 1. 采样场景 ----
        scene_idx = self.valid_scenes[index % len(self.valid_scenes)]
        scene_info = self.scene_structures[scene_idx]
        scene_path = scene_info['scene_path']
        ply_path = scene_info['ply_path']
        structure = scene_info['structure']

        # ---- 2. 采样轨迹 ----
        traj_ids = list(structure.keys())
        traj_id = random.choice(traj_ids)
        traj_data = structure[traj_id]

        # ---- 3. 采样偏移量 (按权重) ----
        available_offsets = list(traj_data.keys())
        offset = self._sample_offset(available_offsets)
        offset_data = traj_data[offset]

        # ---- 4. 获取时间戳序列 ----
        timestamps = sorted(offset_data.keys())
        if len(timestamps) < self.num_frames:
            raise ValueError(f"Not enough frames: {len(timestamps)} < {self.num_frames}")

        # 取最后 num_frames 帧 (与原始代码一致)
        timestamps = timestamps[-self.num_frames:]

        # ---- 5. 采样源相机 (按权重) ----
        # 用第一帧的可用相机列表
        first_ts_cams = list(offset_data[timestamps[0]].keys())
        source_cam = self._sample_camera(first_ts_cams)

        # ---- 6. 加载源视角 RGB ----
        source_frames = []
        for ts in timestamps:
            ts_cams = offset_data[ts]
            if source_cam not in ts_cams:
                raise ValueError(f"Camera {source_cam} missing at timestamp {ts}")
            img = self.load_image_as_tensor(ts_cams[source_cam])
            source_frames.append(img)
        source_video = torch.stack(source_frames, dim=1)  # (3, T, H, W)

        # ---- 7. 获取目标相机 c2w (81帧) ----
        # 接口: target_c2w_provider(scene_path, traj_id, offset, timestamps)
        #        返回 (81, 4, 4) numpy array
        if self.target_c2w_provider is not None:
            target_c2ws = self.target_c2w_provider(
                scene_path, traj_id, offset, timestamps
            )
        else:
            # 从 cameras_extrinsics.json 加载 (fallback)
            cam_json_path = scene_info.get('cameras_json')
            if cam_json_path and os.path.exists(cam_json_path):
                with open(cam_json_path, 'r') as f:
                    cam_data = json.load(f)
                target_c2ws = np.array(cam_data[self.target_cam_json_key],
                                       dtype=np.float32)
            else:
                raise ValueError(
                    "No target_c2w_provider and no cameras_json_path. "
                    "Please provide target camera extrinsics."
                )

        assert target_c2ws.shape == (self.num_frames, 4, 4), \
            f"Expected target_c2ws shape ({self.num_frames}, 4, 4), " \
            f"got {target_c2ws.shape}"

        # ---- 8. 获取源相机 c2w (用于计算 relative pose) ----
        if self.target_c2w_provider is not None:
            # 如果有 provider，也提供源相机
            source_c2ws = self.target_c2w_provider(
                scene_path, traj_id, offset, timestamps,
                camera_type="source"
            )
        else:
            if cam_json_path and os.path.exists(cam_json_path):
                with open(cam_json_path, 'r') as f:
                    cam_data = json.load(f)
                source_c2ws = np.array(cam_data[self.source_cam_json_key],
                                        dtype=np.float32)
            else:
                # 用 target_c2ws 作为 source 的 fallback
                source_c2ws = target_c2ws.copy()

        # ---- 9. 加载目标视角 RGB (如有) ----
        # 目标视角可能和源视角不同，这里先预留
        # 如果目标视角也有原始图像，可以加载
        target_video = source_video.clone()  # placeholder, 根据需求替换

        # ---- 10. PLY 投影: 渲染 lidar_rgb + lidar_mask ----
        renderer = self._get_renderer(ply_path)

        lidar_colors = []
        lidar_masks = []

        for fi in range(self.num_frames):
            c2w = target_c2ws[fi]
            color, mask = self._render_single_frame(renderer, c2w, cam_name=source_cam)
            lidar_colors.append(torch.from_numpy(color))
            lidar_masks.append(torch.from_numpy(mask))

        render_lidar = torch.stack(lidar_colors, dim=1)     # (3, T, H, W)
        render_lidar_mask = torch.stack(lidar_masks, dim=1)  # (1, T, H, W)

        # ---- 11. 计算 relative pose (每4帧采样) ----
        cam_idx = list(range(self.num_frames))[::4]

        source_cam_params = [Camera(source_c2ws[i]) for i in range(self.num_frames)]
        target_cam_params = [Camera(target_c2ws[i]) for i in range(self.num_frames)]

        relative_poses = []
        for i in cam_idx:
            relative_pose = self.get_relative_pose(
                [source_cam_params[i], target_cam_params[i]]
            )
            relative_poses.append(
                torch.as_tensor(relative_pose)[:, :3, :][1]
            )
        pose_embedding = torch.stack(relative_poses, dim=0)  # (21, 3, 4)
        camera_embedding = rearrange(
            pose_embedding, 'b c d -> b (c d)'
        ).to(torch.bfloat16)

        t_total = time.time() - t_start

        return {
            "source_video": source_video,               # (3, T, H, W) float32
            "target_video": target_video,               # (3, T, H, W) float32
            "render_lidar": render_lidar,               # (3, T, H, W) float32
            "render_lidar_mask": render_lidar_mask,     # (1, T, H, W) float32
            "camera_embedding": camera_embedding,       # (21, 12) bfloat16
            "scene_path": scene_path,
            "traj_id": traj_id,
            "offset": offset,
            "source_cam": source_cam,
            "load_time": t_total,
        }


# ============================================================
#  DataLoader 创建
# ============================================================

def create_lidar_projection_loader(
    scene_csv_path: str,
    target_c2w_provider=None,
    batch_size: int = 1,
    num_workers: int = 4,
    **dataset_kwargs
):
    """
    创建 DataLoader

    num_workers > 0: CPU 多进程渲染 (推荐)
    注意: 使用 CPU 渲染时可以多 worker
          使用 O3D 渲染时 num_workers 建议 0 或 1
    """
    dataset = LidarProjectionDataset(
        scene_csv_path=scene_csv_path,
        target_c2w_provider=target_c2w_provider,
        **dataset_kwargs
    )

    loader = DataLoader(
        dataset,
        batch_size=batch_size,
        shuffle=True,
        num_workers=num_workers,
        pin_memory=True,
        persistent_workers=(num_workers > 0),
        prefetch_factor=2 if num_workers > 0 else None,
        drop_last=True,
    )

    return loader


