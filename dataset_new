def test_dataset():
    """
    测试脚本: 验证数据集能正常工作，记录时间和输出
    """
    import argparse
    import matplotlib
    matplotlib.use('Agg')
    import matplotlib.pyplot as plt

    parser = argparse.ArgumentParser(description="Test LidarProjectionDataset")
    parser.add_argument("--scene_csv", type=str, required=True,
                        help="Path to scene CSV (columns: scene_path, ply_path)")
    parser.add_argument("--output_dir", type=str, default="test_output",
                        help="Output directory for visualizations")
    parser.add_argument("--num_samples", type=int, default=3,
                        help="Number of samples to test")
    parser.add_argument("--renderer", type=str, default="cpu",
                        choices=["cpu", "o3d"])
    parser.add_argument("--height", type=int, default=480)
    parser.add_argument("--width", type=int, default=832)
    parser.add_argument("--splat_size", type=int, default=2)
    parser.add_argument("--point_size", type=float, default=3.0)
    parser.add_argument("--num_frames", type=int, default=81)
    args = parser.parse_args()

    os.makedirs(args.output_dir, exist_ok=True)

    print("=" * 60)
    print("Testing LidarProjectionDataset")
    print("=" * 60)

    # --- 简单的 c2w provider (测试用) ---
    def dummy_c2w_provider(scene_path, traj_id, offset, timestamps,
                           camera_type="target"):
        """
        测试用: 生成围绕原点旋转的相机轨迹
        实际使用时替换为真实外参加载
        """
        n = len(timestamps)
        c2ws = []
        for i in range(n):
            theta = np.radians(i * 2)  # 每帧旋转2度
            c2w = np.eye(4, dtype=np.float32)
            c2w[0, 0] = np.cos(theta)
            c2w[0, 2] = np.sin(theta)
            c2w[2, 0] = -np.sin(theta)
            c2w[2, 2] = np.cos(theta)
            c2w[2, 3] = 10  # 距原点 10m
            c2ws.append(c2w)
        return np.array(c2ws, dtype=np.float32)

    # --- 创建 Dataset ---
    print("\nCreating dataset...")
    t0 = time.time()

    dataset = LidarProjectionDataset(
        scene_csv_path=args.scene_csv,
        target_c2w_provider=dummy_c2w_provider,
        num_frames=args.num_frames,
        height=args.height,
        width=args.width,
        steps_per_epoch=args.num_samples * 10,
        renderer_type=args.renderer,
        splat_size=args.splat_size,
        point_size=args.point_size,
        max_points=3_000_000,
    )
    print(f"Dataset created in {time.time() - t0:.2f}s")
    print(f"  Scenes: {len(dataset.valid_scenes)}")
    print(f"  Renderer: {args.renderer}")
    print(f"  Splat/Point size: {args.splat_size}/{args.point_size}")

    # --- 逐样本测试 ---
    load_times = []
    render_times_per_frame = []

    for sample_idx in range(args.num_samples):
        print(f"\n--- Sample {sample_idx + 1}/{args.num_samples} ---")

        t0 = time.time()
        try:
            data = dataset[sample_idx]
        except Exception as e:
            print(f"  ERROR: {e}")
            continue
        total_time = time.time() - t0
        load_times.append(total_time)

        inner_time = data['load_time']
        per_frame = inner_time / args.num_frames
        render_times_per_frame.append(per_frame)

        print(f"  Scene:   {data['scene_path']}")
        print(f"  Traj:    {data['traj_id']}")
        print(f"  Offset:  {data['offset']}")
        print(f"  Camera:  {data['source_cam']}")
        print(f"  Time:    {total_time:.2f}s total, {per_frame * 1000:.1f}ms/frame")

        # 打印 tensor shapes
        for key in ['source_video', 'target_video', 'render_lidar',
                     'render_lidar_mask', 'camera_embedding']:
            if key in data and isinstance(data[key], torch.Tensor):
                print(f"  {key:25s}: {list(data[key].shape)}, "
                      f"dtype={data[key].dtype}")

        # --- 可视化 ---
        sample_dir = os.path.join(args.output_dir, f"sample_{sample_idx:03d}")
        os.makedirs(sample_dir, exist_ok=True)

        # 保存几帧可视化
        vis_frame_indices = [0, args.num_frames // 4,
                             args.num_frames // 2,
                             3 * args.num_frames // 4,
                             args.num_frames - 1]

        for fi in vis_frame_indices:
            fig, axes = plt.subplots(1, 4, figsize=(24, 6))

            # source
            src = data['source_video'][:, fi]  # (3, H, W)
            src = (src * 0.5 + 0.5).clamp(0, 1).permute(1, 2, 0).numpy()
            axes[0].imshow(src)
            axes[0].set_title(f"Source (frame {fi})")

            # target
            tgt = data['target_video'][:, fi]
            tgt = (tgt * 0.5 + 0.5).clamp(0, 1).permute(1, 2, 0).numpy()
            axes[1].imshow(tgt)
            axes[1].set_title(f"Target (frame {fi})")

            # lidar render
            lidar = data['render_lidar'][:, fi]
            lidar_np = lidar.permute(1, 2, 0).numpy()
            axes[2].imshow(lidar_np)
            axes[2].set_title(f"LiDAR render (frame {fi})")

            # lidar mask
            mask = data['render_lidar_mask'][0, fi]
            axes[3].imshow(mask.numpy(), cmap='gray')
            axes[3].set_title(f"LiDAR mask (frame {fi})")

            for ax in axes:
                ax.axis('off')

            plt.tight_layout()
            plt.savefig(os.path.join(sample_dir, f"frame_{fi:03d}.png"),
                        dpi=100, bbox_inches='tight')
            plt.close()

        # 保存 lidar 渲染视频 (所有帧)
        lidar_frames = []
        for fi in range(args.num_frames):
            lidar_f = data['render_lidar'][:, fi].permute(1, 2, 0).numpy()
            lidar_f = (lidar_f * 255).clip(0, 255).astype(np.uint8)
            lidar_frames.append(lidar_f)

        # 保存为 mp4
        try:
            import imageio
            video_path = os.path.join(sample_dir, "render_lidar.mp4")
            writer = imageio.get_writer(video_path, fps=10)
            for frame in lidar_frames:
                writer.append_data(frame)
            writer.close()
            print(f"  Saved video: {video_path}")
        except Exception as e:
            print(f"  Video save failed: {e}")

    # --- 统计 ---
    print("\n" + "=" * 60)
    print("SUMMARY")
    print("=" * 60)
    if load_times:
        print(f"  Samples tested:       {len(load_times)}")
        print(f"  Avg total time:       {np.mean(load_times):.2f}s")
        print(f"  Avg per-frame render: {np.mean(render_times_per_frame) * 1000:.1f}ms")
        print(f"  Est. FPS:             {1.0 / np.mean(render_times_per_frame):.1f}")
        print(f"  Est. time for 81 frames: "
              f"{np.mean(render_times_per_frame) * 81:.2f}s")
    else:
        print("  No samples loaded successfully!")

    print(f"\nOutput saved to: {args.output_dir}")
    print("Done!")


