# 11 个相机名 (按文件名中的关键字)
CAMERA_NAMES = [
    "FRONT_LEFT_RESET_OPTICAL_H99",
    "FRONT_RIGHT_RESET_OPTICAL_H99",
    "FRONT_TELE_RESET_OPTICAL_H15",
    "FRONT_TELE_RESET_OPTICAL_H30",
    "FRONT_WIDE_RESET_OPTICAL_H110",
    "FRONT_WIDE_RESET_OPTICAL_H60",
    "REAR_LEFT_RESET_OPTICAL_H30",
    "REAR_LEFT_RESET_OPTICAL_H99",
    "REAR_RESET_OPTICAL_H50",
    "REAR_RIGHT_RESET_OPTICAL_H30",
    "REAR_RIGHT_RESET_OPTICAL_H99",
]

# 偏移量列表
OFFSET_LIST = [
    "+1.0m", "+2.0m", "+4.0m",
    "-1.0m", "-2.0m", "-4.0m",
    "0.0m",
]


def parse_scene_structure(scene_root: str):
    """
    解析一个场景的目录结构

    Returns:
        trajectories: dict
            {
                traj_id: {
                    offset_name: {
                        timestamp: {
                            cam_name: image_path,
                            ...
                        },
                        ...
                    },
                    ...
                },
                ...
            }
    """
    trajectories = {}

    for traj_name in sorted(os.listdir(scene_root)):
        traj_path = os.path.join(scene_root, traj_name)
        if not os.path.isdir(traj_path) or traj_name.endswith('.zip'):
            continue
        # 跳过非轨迹目录
        if 'offset' in traj_name:
            continue

        trajectories[traj_name] = {}

        for offset_dir in sorted(os.listdir(traj_path)):
            offset_path = os.path.join(traj_path, offset_dir)
            if not os.path.isdir(offset_path):
                continue
            if 'offset' not in offset_dir:
                continue

            # 提取偏移量
            offset_match = offset_dir.split('offset_')[-1]  # e.g. "+1.0m"

            trajectories[traj_name][offset_match] = {}

            # 遍历时间戳目录
            for ts_name in sorted(os.listdir(offset_path)):
                ts_path = os.path.join(offset_path, ts_name)
                if not os.path.isdir(ts_path):
                    continue
                try:
                    ts = int(ts_name)
                except ValueError:
                    continue

                # 收集该时间戳下的所有相机图像
                cam_images = {}
                for fname in os.listdir(ts_path):
                    if not fname.endswith('.jpg') and not fname.endswith('.png'):
                        continue
                    for cam_name in CAMERA_NAMES:
                        if cam_name in fname:
                            cam_images[cam_name] = os.path.join(ts_path, fname)
                            break

                if cam_images:
                    trajectories[traj_name][offset_match][ts] = cam_images

    return trajectories


