def test_renderer_standalone():
    """
    独立测试渲染器 (用随机点云)
    不需要真实数据文件
    """
    import tempfile

    print("Testing renderer with random point cloud...")

    # 生成随机点云
    N = 100000
    points = np.random.randn(N, 3).astype(np.float32) * 10
    colors = np.random.rand(N, 3).astype(np.float32)

    pcd = o3d.geometry.PointCloud()
    pcd.points = o3d.utility.Vector3dVector(points)
    pcd.colors = o3d.utility.Vector3dVector(colors)

    # 保存临时 ply
    with tempfile.NamedTemporaryFile(suffix='.ply', delete=False) as f:
        tmp_ply = f.name
    o3d.io.write_point_cloud(tmp_ply, pcd, write_ascii=False)

    # 内参
    K = np.array([
        [500, 0, 416],
        [0, 500, 240],
        [0, 0, 1]
    ], dtype=np.float32)

    # 外参
    c2w = np.eye(4, dtype=np.float32)
    c2w[2, 3] = 20  # 相机在 z=20
    w2c = np.linalg.inv(c2w)

    # CPU 渲染
    print("\n--- CPU Renderer ---")
    cpu_renderer = CPUPointCloudRenderer(tmp_ply)
    t0 = time.time()
    for _ in range(10):
        color, mask = cpu_renderer.render(K, w2c, 480, 832, splat_size=2)
    avg_cpu = (time.time() - t0) / 10
    print(f"  Color: {color.shape}, Mask: {mask.shape}")
    print(f"  Avg time: {avg_cpu * 1000:.1f}ms")
    print(f"  Coverage: {mask.mean():.1%}")

    # O3D 渲染
    print("\n--- O3D Renderer ---")
    o3d_renderer = O3DPointCloudRenderer(tmp_ply)
    # warmup
    o3d_renderer.render(K, w2c, 480, 832, point_size=3.0)
    t0 = time.time()
    for _ in range(10):
        color, mask = o3d_renderer.render(K, w2c, 480, 832, point_size=3.0)
    avg_o3d = (time.time() - t0) / 10
    print(f"  Color: {color.shape}, Mask: {mask.shape}")
    print(f"  Avg time: {avg_o3d * 1000:.1f}ms")
    print(f"  Coverage: {mask.mean():.1%}")
    o3d_renderer.cleanup()

    # 可视化
    print("\nSaving test renders...")
    for name, arr in [("cpu_render", color)]:
        img = (arr.transpose(1, 2, 0) * 255).clip(0, 255).astype(np.uint8)
        cv2.imwrite(f"test_{name}.png", cv2.cvtColor(img, cv2.COLOR_RGB2BGR))

    # 清理
    os.remove(tmp_ply)
    print("Done!")


if __name__ == "__main__":
    import sys

    if len(sys.argv) > 1 and sys.argv[1] == "--test-renderer":
        test_renderer_standalone()
    else:
        test_dataset()
